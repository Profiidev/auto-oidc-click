{
  "manifest_version": 3,
  "name": "Cloudflare Access Auto-OIDC",
  "version": "1.0",
  "description": "Automatically selects OIDC on Cloudflare Access pages.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.cloudflareaccess.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
